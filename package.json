{
  "name": "muji-shop",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "nuxt build",
    "dev": "npm run db:wait && nuxt dev --port 3001",
    "dev:open": "npm run db:wait && nuxt dev --port 3001 --open",
    "dev:docker": "npm run db:up && npm run db:wait && nuxt dev --port 3001",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",

    "db:up": "docker compose up -d",
    "db:wait": "node scripts/wait-for-db.mjs",
    "db:generate": "prisma generate --schema server/prisma/schema.prisma",
    "db:push": "prisma db push --schema server/prisma/schema.prisma",
    "db:seed": "tsx server/prisma/seed.ts",
    "db:init": "npm run db:wait && npm run db:push && npm run db:seed",
    "db:init:docker": "npm run db:up && npm run db:wait && npm run db:push && npm run db:seed",
    "db:studio": "prisma studio --schema server/prisma/schema.prisma",

    "typecheck": "nuxt typecheck",
    "lint": "eslint ."
  },
  "dependencies": {
    "@nuxt/eslint": "^1.16.0",
    "@nuxt/icon": "^2.2.4",
    "@nuxt/image": "^2.0.0",
    "@nuxt/ui": "^4.9.0",
    "@pinia/nuxt": "^0.11.3",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "@vueuse/nuxt": "^14.3.0",
    "animate.css": "^4.1.1",
    "eslint": "^10.6.0",
    "nuxt": "^4.4.8",
    "nuxt-auth-utils": "^0.5.29",
    "pinia": "^3.0.4",
    "tailwindcss": "^4.3.1",
    "vue": "^3.5.38",
    "vue-router": "^5.1.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "dotenv": "^17.4.2",
    "pg": "^8.22.0",
    "prettier": "^3.9.1",
    "prisma": "^7.8.0",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vue-tsc": "^3.3.5"
  }
}
