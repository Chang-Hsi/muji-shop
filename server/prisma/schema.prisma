generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model HomeNews {
  id        Int      @id @default(autoincrement())
  html      String
  image     String?
  to        String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([isActive, sortOrder])
}

model Category {
  id          Int       @id @default(autoincrement())
  title       String
  description String
  slug        String    @unique
  tag         String
  image       String
  sortOrder   Int       @default(0)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  products    Product[]

  @@index([isActive, sortOrder])
}

model Product {
  id               Int                    @id @default(autoincrement())
  name             String
  slug             String                 @unique
  price            Int
  mainImage        String
  description      String?
  fullDescription  String                 @default("")
  material         String                 @default("")
  color            String                 @default("")
  sales            Int                    @default(0)
  stock            Int                    @default(0)
  isNew            Boolean                @default(false)
  isLimited        Boolean                @default(false)
  careInstructions String                 @default("")
  badge            String?
  isFeatured       Boolean                @default(false)
  sortOrder        Int                    @default(0)
  isActive         Boolean                @default(true)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  categoryId       Int
  category         Category               @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  images           ProductImage[]
  swatches         ProductSwatch[]
  topics           ProductTopic[]
  specifications   ProductSpecification[]

  @@index([categoryId])
  @@index([material])
  @@index([color])
  @@index([price])
  @@index([isActive])
  @@index([isFeatured, isActive, sortOrder])
}

model ProductImage {
  id        Int      @id @default(autoincrement())
  url       String
  alt       String?
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, isActive, sortOrder])
}

model ProductSwatch {
  id        Int      @id @default(autoincrement())
  label     String
  hex       String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
}

model ProductTopic {
  id        Int      @id @default(autoincrement())
  value     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([value])
  @@index([productId])
}

model ProductSpecification {
  id        Int      @id @default(autoincrement())
  label     String
  value     String
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  productId Int
  product   Product  @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId, sortOrder])
}

model StoreGroup {
  id        Int      @id @default(autoincrement())
  key       String   @unique
  label     String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  stores    Store[]

  @@index([isActive, sortOrder])
}

model Store {
  id           Int                   @id @default(autoincrement())
  title        String
  name         String                @default("")
  slug         String                @unique
  region       String                @default("")
  regionLabel  String                @default("")
  address      String                @default("")
  phone        String                @default("")
  hours        String                @default("")
  image        String
  facadeImage  String?
  layoutImages Json                  @default("[]")
  lat          Float                 @default(0)
  lng          Float                 @default(0)
  sortOrder    Int                   @default(0)
  isActive     Boolean               @default(true)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt
  storeGroupId Int
  storeGroup   StoreGroup            @relation(fields: [storeGroupId], references: [id], onDelete: Cascade)
  services     StoreServiceOnStore[]

  @@index([storeGroupId, isActive, sortOrder])
  @@index([region])
}

model StoreService {
  id          Int                   @id @default(autoincrement())
  title       String
  slug        String                @unique
  category    String
  badge       String?
  description String
  detail      String
  image       String
  buttonText  String
  features    Json                  @default("[]")
  sortOrder   Int                   @default(0)
  isActive    Boolean               @default(true)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt
  stores      StoreServiceOnStore[]

  @@index([isActive, sortOrder])
}

model StoreServiceOnStore {
  storeId        Int
  storeServiceId Int
  sortOrder      Int          @default(0)
  store          Store        @relation(fields: [storeId], references: [id], onDelete: Cascade)
  storeService   StoreService @relation(fields: [storeServiceId], references: [id], onDelete: Cascade)

  @@id([storeId, storeServiceId])
  @@index([storeServiceId])
}
